# Copy only to a local, ignored file before using `supabase secrets set --env-file`.
# Never expose these values with a VITE_ prefix or commit real credentials.

PUBLIC_SITE_URL=https://www.example.com

# Azul - request separate credentials for sandbox and production.
AZUL_MERCHANT_ID=replace_me
AZUL_MERCHANT_NAME=replace_me
AZUL_MERCHANT_TYPE=ECommerce
AZUL_CURRENCY_CODE=$
AZUL_AUTH_KEY=replace_me
# Optional override. The function selects the official sandbox/production URL by default.
# AZUL_PAYMENT_URL=https://pruebas.azul.com.do/PaymentPage/

# CardNET - values are assigned during affiliation/certification.
CARDNET_MERCHANT_NUMBER=replace_me
CARDNET_MERCHANT_TERMINAL=replace_me
CARDNET_MERCHANT_NAME=REPLACE WITH CARDNET APPROVED NAME
CARDNET_MERCHANT_TYPE=5440
CARDNET_ACQUIRING_CODE=349
CARDNET_DEFAULT_STATE=DN
CARDNET_DEFAULT_POSTCODE=10101
CARDNET_COUNTRY_CODE=DOP
# Optional overrides. Official URLs are selected from the Admin environment by default.
# CARDNET_SESSIONS_URL=https://labservicios.cardnet.com.do/sessions
# CARDNET_AUTHORIZE_URL=https://labservicios.cardnet.com.do/authorize

# Transactional email.
RESEND_API_KEY=replace_me
ORDER_EMAIL_FROM=Barbaro Nutrition <pedidos@example.com>
